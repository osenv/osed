# OSED connectors — environment configuration
#
# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
#
# Keyless (need NO configuration): Federal Register, eCFR, and GovInfo (US Code).
# GovInfo US Code text is fetched via the keyless link service, so no api.data.gov
# key is required for it.

# --- Regulations.gov (one of two keyed sources) ---
# Free key from https://api.data.gov/signup  (DEMO_KEY works for light testing).
# Sent in the X-Api-Key header, never in a URL.
REGULATIONS_GOV_API_KEY=

# --- CourtListener (case citation verification) ---
# Free token from https://www.courtlistener.com (sign up, then profile → API).
# Sent in the Authorization header (Token ...), never in a URL.
COURTLISTENER_API_KEY=
