# OSED connectors — environment configuration
#
# Phase 1 (Federal Register + eCFR) needs NO keys; this file documents the
# keys the phase-2 connectors (GovInfo + Regulations.gov) will require.
#
# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.

# --- Phase 2 (not yet used) ---
# Free key from https://api.data.gov/signup  (DEMO_KEY works for light testing)
REGULATIONS_GOV_API_KEY=
# Free key from https://api.data.gov/signup
GOVINFO_API_KEY=
